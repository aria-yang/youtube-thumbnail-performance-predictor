from pathlib import Path
import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from loguru import logger
import dateutil.parser
import typer

# Reusing the project's config paths
from thumbnail_performance.config import PROCESSED_DATA_DIR, RAW_DATA_DIR

app = typer.Typer()

def validate_splits(train, val, test, split_name, check_channel_leakage=False):
    """
    Validates that there is no data leakage (overlap) between train/val/test splits.
    """
    train_ids = set(train['Id'])
    val_ids = set(val['Id'])
    test_ids = set(test['Id'])
    
    assert len(train_ids.intersection(val_ids)) == 0, f"{split_name}: Train/Val overlap detected!"
    assert len(train_ids.intersection(test_ids)) == 0, f"{split_name}: Train/Test overlap detected!"
    assert len(val_ids.intersection(test_ids)) == 0, f"{split_name}: Val/Test overlap detected!"
    
    if check_channel_leakage:
        train_channels = set(train['Channel'])
        val_channels = set(val['Channel'])
        test_channels = set(test['Channel'])
        assert len(train_channels.intersection(val_channels)) == 0, "Channel leakage between Train/Val!"
        assert len(train_channels.intersection(test_channels)) == 0, "Channel leakage between Train/Test!"
        assert len(val_channels.intersection(test_channels)) == 0, "Channel leakage between Val/Test!"
        
    logger.success(f"Validation passed for {split_name} split. No leakage detected.")

def create_random_split(df, train_frac=0.7, val_frac=0.15, test_frac=0.15, seed=42):
    """Creates a standard random split (70/15/15)."""
    train_df, temp_df = train_test_split(df, test_size=(val_frac + test_frac), random_state=seed)
    val_df, test_df = train_test_split(temp_df, test_size=(test_frac / (val_frac + test_frac)), random_state=seed)
    
    validate_splits(train_df, val_df, test_df, "Random")
    return train_df, val_df, test_df

def create_channel_heldout_split(df, train_frac=0.7, val_frac=0.15, test_frac=0.15, seed=42):
    """
    Creates a split where specific channels are entirely held out for validation and testing.
    This tests if the model learns general features or just memorizes creator-specific styles.
    """
    channels = df['Channel'].unique()
    
    # Split the channels
    train_channels, temp_channels = train_test_split(channels, test_size=(val_frac + test_frac), random_state=seed)
    val_channels, test_channels = train_test_split(temp_channels, test_size=(test_frac / (val_frac + test_frac)), random_state=seed)
    
    train_df = df[df['Channel'].isin(train_channels)]
    val_df = df[df['Channel'].isin(val_channels)]
    test_df = df[df['Channel'].isin(test_channels)]
    
    validate_splits(train_df, val_df, test_df, "Channel-Heldout", check_channel_leakage=True)
    return train_df, val_df, test_df

def safe_parse_date(date_str):
    """Helper to parse dates robustly."""
    try:
        return dateutil.parser.parse(str(date_str))
    except:
        return pd.NaT

def create_time_based_split(df, train_frac=0.7, val_frac=0.15):
    """
    Splits data chronologically to simulate real-world deployment (predicting future performance).
    """
    df_time = df.copy()
    df_time['parsed_date'] = df_time['Released'].apply(safe_parse_date)
    
    # Drop rows with unparseable dates just for the split logic
    df_time = df_time.dropna(subset=['parsed_date']).sort_values('parsed_date')
    
    n = len(df_time)
    train_end = int(n * train_frac)
    val_end = int(n * (train_frac + val_frac))
    
    train_df = df_time.iloc[:train_end].drop(columns=['parsed_date'])
    val_df = df_time.iloc[train_end:val_end].drop(columns=['parsed_date'])
    test_df = df_time.iloc[val_end:].drop(columns=['parsed_date'])
    
    validate_splits(train_df, val_df, test_df, "Time-Based")
    return train_df, val_df, test_df

@app.command()
def main(
    # Adjusted to point to the processed folder from previous step
    input_csv: Path = PROCESSED_DATA_DIR / "labeled_data.csv",
    # Save splits in a new 'splits' directory inside data folder
    output_dir: Path = PROCESSED_DATA_DIR.parent / "splits"
):
    logger.info(f"Loading data from {input_csv}")
    
    if not input_csv.exists():
        logger.error(f"Could not find file at {input_csv}. Please run dataset.py first!")
        raise FileNotFoundError(f"Missing {input_csv}")
        
    df = pd.read_csv(input_csv)
    output_dir.mkdir(parents=True, exist_ok=True)
    
    logger.info("Generating dataset splits...")
    splits = {
        "random": create_random_split(df),
        "channel": create_channel_heldout_split(df),
        "time": create_time_based_split(df)
    }
    
    for split_type, (train, val, test) in splits.items():
        train.to_csv(output_dir / f"{split_type}_train.csv", index=False)
        val.to_csv(output_dir / f"{split_type}_val.csv", index=False)
        test.to_csv(output_dir / f"{split_type}_test.csv", index=False)
        logger.info(f"Saved {split_type} splits -> Train: {len(train)}, Val: {len(val)}, Test: {len(test)}")
        
    logger.success(f"All splits successfully generated and saved to {output_dir}")

if __name__ == "__main__":
    app()